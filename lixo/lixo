<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Buscar Dados SQL</title>
    <link rel="stylesheet" href="./lixo.css" />
  </head>
  <body>
    <div id="cen">
      <div id="status">Conectando ao SQL Server...</div>
      <h2>Dados do SQL Server:</h2>

      <label id="nameProcedure" for="procedure">Nome da Procedure:</label>
      <input
        type="text"
        id="procedure"
        placeholder="Digite o nome da procedure"
      />
      <button id="buscar" onclick="buscarDadosDaProcedure()">
        Buscar Dados
      </button>
    </div>

    <div id="result">
      <label>Lista de Itens do Banco:</label>

      <ul id="lista-itens">
        <li>Carregando itens...</li>
      </ul>
    </div>

    <script src="./script.js"></script>
  </body>
</html>
